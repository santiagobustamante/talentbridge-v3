{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": ".",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "tsconfig.json"
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "candidate-service": {
      "type": "application",
      "root": "apps/candidate-service",
      "entryFile": "main",
      "sourceRoot": "apps/candidate-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/candidate-service/tsconfig.app.json"
      }
    },
    "portfolio-service": {
      "type": "application",
      "root": "apps/portfolio-service",
      "entryFile": "main",
      "sourceRoot": "apps/portfolio-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/portfolio-service/tsconfig.app.json"
      }
    },
    "company-service": {
      "type": "application",
      "root": "apps/company-service",
      "entryFile": "main",
      "sourceRoot": "apps/company-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/company-service/tsconfig.app.json"
      }
    },
    "jobs-service": {
      "type": "application",
      "root": "apps/jobs-service",
      "entryFile": "main",
      "sourceRoot": "apps/jobs-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/jobs-service/tsconfig.app.json"
      }
    },
    "applications-service": {
      "type": "application",
      "root": "apps/applications-service",
      "entryFile": "main",
      "sourceRoot": "apps/applications-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/applications-service/tsconfig.app.json"
      }
    },
    "chat-service": {
      "type": "application",
      "root": "apps/chat-service",
      "entryFile": "main",
      "sourceRoot": "apps/chat-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/chat-service/tsconfig.app.json"
      }
    },
    "assistant-service": {
      "type": "application",
      "root": "apps/assistant-service",
      "entryFile": "main",
      "sourceRoot": "apps/assistant-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/assistant-service/tsconfig.app.json"
      }
    },
    "dashboard-service": {
      "type": "application",
      "root": "apps/dashboard-service",
      "entryFile": "main",
      "sourceRoot": "apps/dashboard-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/dashboard-service/tsconfig.app.json"
      }
    },
    "database-lib": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "auth-lib": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "common-lib": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "contracts-lib": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "events-lib": {
      "type": "library",
      "root": "libs/events",
      "entryFile": "index",
      "sourceRoot": "libs/events/src",
      "compilerOptions": {
        "tsConfigPath": "libs/events/tsconfig.lib.json"
      }
    }
  }
}
