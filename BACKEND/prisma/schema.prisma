generator client {
  provider     = "prisma-client"
  output       = "../libs/database/src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  COMPANY
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  role           UserRole        @default(CANDIDATE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  profile        Profile?
  companyProfile CompanyProfile?
  cvDocuments    CvDocument[]
  profileViews   ProfileView[]

  candidateConversations Conversation[]     @relation("CandidateConversations")
  companyConversations   Conversation[]     @relation("CompanyConversations")
  sentChatMessages       ChatMessage[]      @relation("SentChatMessages")
  chatBlocksMade         ChatBlock[]        @relation("ChatBlocksMade")
  chatBlocksReceived     ChatBlock[]        @relation("ChatBlocksReceived")
  jobOffers              JobOffer[]
  jobApplications        JobApplication[]
  skillEndorsementsGiven SkillEndorsement[]
  notifications          Notification[]

  @@map("users")
}

model Profile {
  id                Int           @id @default(autoincrement())
  userId            Int           @unique @map("user_id")
  fullName          String?       @map("full_name")
  professionalTitle String?       @map("professional_title")
  summary           String?
  phone             String?
  city              String?
  photoUrl          String?       @map("photo_url")
  linkedinUrl       String?       @map("linkedin_url")
  githubUrl         String?       @map("github_url")
  websiteUrl        String?       @map("website_url")
  slug              String        @unique
  isPublished       Boolean       @default(false) @map("is_published")
  showPhone         Boolean       @default(false) @map("show_phone")
  showCity          Boolean       @default(true) @map("show_city")
  showLinkedin      Boolean       @default(true) @map("show_linkedin")
  showGithub        Boolean       @default(true) @map("show_github")
  showWebsite       Boolean       @default(true) @map("show_website")
  showExperience    Boolean       @default(true) @map("show_experience")
  showEducation     Boolean       @default(true) @map("show_education")
  showProjects      Boolean       @default(true) @map("show_projects")
  showSkills        Boolean       @default(true) @map("show_skills")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills            Skill[]
  experiences       Experience[]
  educations        Education[]
  projects          Project[]
  views             ProfileView[]

  @@map("profiles")
}

model ProfileView {
  id            Int      @id @default(autoincrement())
  profileId     Int      @map("profile_id")
  companyUserId Int      @map("company_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyUser   User     @relation(fields: [companyUserId], references: [id], onDelete: Cascade)

  @@map("profile_views")
}

model CompanyProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  companyName String   @map("company_name")
  nit         String?
  sector      String?
  city        String?
  phone       String?
  websiteUrl  String?  @map("website_url")
  description String?
  logoUrl     String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model Skill {
  id             Int                @id @default(autoincrement())
  profileId      Int                @map("profile_id")
  name           String
  normalizedName String             @map("normalized_name")
  level          String             @default("BASIC")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  profile        Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  endorsements   SkillEndorsement[]

  @@unique([profileId, normalizedName])
  @@map("skills")
}

model SkillEndorsement {
  id        Int      @id @default(autoincrement())
  skillId   Int      @map("skill_id")
  companyId Int      @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")

  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  company User  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([skillId, companyId])
  @@map("skill_endorsements")
}

model Experience {
  id            Int       @id @default(autoincrement())
  profileId     Int       @map("profile_id")
  company       String
  position      String
  city          String?   @map("city")
  workMode      String?   @map("work_mode")
  contractType  String?   @map("contract_type")
  description   String?
  functions     String?
  achievements  String?
  tools         String?
  learnedSkills String[]  @map("learned_skills")
  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  isCurrent     Boolean   @default(false) @map("is_current")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id             Int       @id @default(autoincrement())
  profileId      Int       @map("profile_id")
  institution    String
  degree         String
  fieldOfStudy   String?   @map("field_of_study")
  educationType  String    @default("FORMAL") @map("education_type")
  formationLevel String?   @map("formation_level")
  description    String?
  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  isCurrent      Boolean   @default(false) @map("is_current")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  profile        Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Project {
  id               Int       @id @default(autoincrement())
  profileId        Int       @map("profile_id")
  name             String
  description      String?
  role             String?
  responsibilities String?
  technologies     String[]
  repositoryUrl    String?   @map("repository_url")
  demoUrl          String?   @map("demo_url")
  imageUrl         String?   @map("image_url")
  projectType      String?   @map("project_type")
  status           String?
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  profile          Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model CvDocument {
  id            Int          @id @default(autoincrement())
  userId        Int          @map("user_id")
  originalName  String       @map("original_name")
  filePath      String       @map("file_path")
  mimeType      String       @map("mime_type")
  extractedText String?      @map("extracted_text")
  uploadedAt    DateTime     @default(now()) @map("uploaded_at")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses      CvAnalysis[]

  @@map("cv_documents")
}

model CvAnalysis {
  id              Int        @id @default(autoincrement())
  cvDocumentId    Int        @map("cv_document_id")
  score           Int
  strengths       String[]
  recommendations String[]
  createdAt       DateTime   @default(now()) @map("created_at")
  cvDocument      CvDocument @relation(fields: [cvDocumentId], references: [id], onDelete: Cascade)

  @@map("cv_analyses")
}

model Conversation {
  id            Int       @id @default(autoincrement())
  candidateId   Int       @map("candidate_id")
  companyId     Int       @map("company_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastMessageAt DateTime? @map("last_message_at")

  candidate User @relation("CandidateConversations", fields: [candidateId], references: [id], onDelete: Cascade)
  company   User @relation("CompanyConversations", fields: [companyId], references: [id], onDelete: Cascade)

  messages ChatMessage[]
  blocks   ChatBlock[]

  @@unique([candidateId, companyId])
  @@index([candidateId])
  @@index([companyId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ChatMessage {
  id             Int       @id @default(autoincrement())
  conversationId Int       @map("conversation_id")
  senderId       Int       @map("sender_id")
  body           String
  createdAt      DateTime  @default(now()) @map("created_at")
  readAt         DateTime? @map("read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentChatMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatBlock {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  blockerId      Int      @map("blocker_id")
  blockedId      Int      @map("blocked_id")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  blocker      User         @relation("ChatBlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked      User         @relation("ChatBlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([conversationId, blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("chat_blocks")
}

enum JobOfferStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum JobApplicationStatus {
  PENDING
  REVIEWED
  PRESELECTED
  REJECTED
  HIRED
}

model JobOffer {
  id                 Int            @id @default(autoincrement())
  companyId          Int            @map("company_id")
  title              String
  description        String
  requirements       String?
  responsibilities   String?
  city               String?
  modality           String?
  contractType       String?        @map("contract_type")
  customContractType String?        @map("custom_contract_type")
  workload           String?
  customWorkload     String?        @map("custom_workload")
  salaryMin          Int?           @map("salary_min")
  salaryMax          Int?           @map("salary_max")
  currency           String?        @default("COP")
  skillsRequired     String?        @map("skills_required")
  status             JobOfferStatus @default(DRAFT)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  publishedAt        DateTime?      @map("published_at")
  closedAt           DateTime?      @map("closed_at")

  company      User             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([companyId])
  @@index([status])
  @@index([city])
  @@index([createdAt])
  @@map("job_offers")
}

model JobApplication {
  id           Int                  @id @default(autoincrement())
  jobOfferId   Int                  @map("job_offer_id")
  candidateId  Int                  @map("candidate_id")
  coverMessage String?              @map("cover_message")
  status       JobApplicationStatus @default(PENDING)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  jobOffer  JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  candidate User     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobOfferId, candidateId])
  @@index([candidateId])
  @@index([jobOfferId])
  @@index([status])
  @@map("job_applications")
}

/**
 * Tipo de evento que genera una notificación in-app. NEW_APPLICATION y
 * APPLICATION_STATUS_CHANGED se disparan desde applications-service (los dos
 * puntos donde ya existía el evento real: alguien se postula, alguien cambia
 * el estado). JOB_MATCH se dispara desde jobs-service al publicar una vacante
 * nueva, para los candidatos cuyo perfil matchea razonablemente los requisitos.
 */
enum NotificationType {
  NEW_APPLICATION
  APPLICATION_STATUS_CHANGED
  JOB_MATCH
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
