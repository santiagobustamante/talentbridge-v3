{
  "name": "talentbridge-microservices",
  "version": "3.0.0",
  "description": "TalentBridge - Arquitectura de Microservicios",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",

    "start:gateway": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service --watch",
    "start:candidate": "nest start candidate-service --watch",
    "start:portfolio": "nest start portfolio-service --watch",
    "start:company": "nest start company-service --watch",
    "start:jobs": "nest start jobs-service --watch",
    "start:applications": "nest start applications-service --watch",
    "start:chat": "nest start chat-service --watch",
    "start:assistant": "nest start assistant-service --watch",
    "start:dashboard": "nest start dashboard-service --watch",

    "build:gateway": "nest build api-gateway",
    "build:auth": "nest build auth-service",
    "build:candidate": "nest build candidate-service",
    "build:portfolio": "nest build portfolio-service",
    "build:company": "nest build company-service",
    "build:jobs": "nest build jobs-service",
    "build:applications": "nest build applications-service",
    "build:chat": "nest build chat-service",
    "build:assistant": "nest build assistant-service",
    "build:dashboard": "nest build dashboard-service",
    "build:libs": "nest build database-lib && nest build auth-lib && nest build common-lib && nest build contracts-lib && nest build events-lib",

    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "seed": "ts-node prisma/seed.ts",
    "seed:jobs": "ts-node prisma/seed-jobs.ts",
    "seed:santiago": "ts-node prisma/seed-santiago-profile.ts",
    "seed:company-demo": "ts-node prisma/seed-company-demo.ts",
    "clear:santiago-cvs": "ts-node prisma/clear-santiago-cvs.ts",
    "seed:more-companies": "ts-node prisma/seed-more-companies.ts",
    "seed:skills-catalog": "ts-node prisma/seed-skills-catalog.ts",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "moduleNameMapper": {
      "^@app/database(.*)$": "<rootDir>/libs/database/src/$1",
      "^@app/auth(.*)$": "<rootDir>/libs/auth/src/$1",
      "^@app/common(.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/contracts(.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@app/events(.*)$": "<rootDir>/libs/events/src/$1"
    },
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
